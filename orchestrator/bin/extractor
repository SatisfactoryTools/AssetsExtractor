#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Command\CheckCommand;
use App\Command\MigrateCommand;
use App\Command\RunCommand;
use App\Config;
use Symfony\Component\Console\Application;

require __DIR__ . '/../vendor/autoload.php';

$config = Config::load();

$app = new Application('sf-extractor', '0.1.0');
$app->addCommand(new CheckCommand($config));
$app->addCommand(new RunCommand($config));
$app->addCommand(new MigrateCommand($config));
$app->run();
