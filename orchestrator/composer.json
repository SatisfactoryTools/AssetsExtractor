{
    "name": "sftools/assets-extractor",
    "description": "Satisfactory assets extractor — orchestrator (version watcher, state, pipeline)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.5",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "satisfactory-tools/docs-parser": "^1.0.1",
        "symfony/console": "^8.0",
        "symfony/process": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "bin": [
        "bin/extractor"
    ],
    "config": {
        "sort-packages": true
    }
}
